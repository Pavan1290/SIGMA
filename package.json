{
  "name": "sigma-os-assistant",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "electron:dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && cross-env ELECTRON_START_URL=http://localhost:5173 electron .\"",
    "electron:start": "electron .",
    "sidebar:start": "node scripts/start-sidebar-detached.cjs",
    "electron:pack": "npm run build && electron-builder",
    "shortcut:create": "node scripts/create-desktop-shortcut.cjs"
  },
  "dependencies": {
    "body-parser": "^2.2.0",
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "puppeteer": "^23.0.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.36.0",
    "@types/react": "^19.1.16",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^5.0.4",
    "app-builder-bin": "^5.0.0-alpha.10",
    "autoprefixer": "^10.4.21",
    "babel-plugin-react-compiler": "^19.1.0-rc.3",
    "concurrently": "^8.2.0",
    "cross-env": "^7.0.3",
    "electron": "^26.0.0",
    "electron-builder": "^25.1.8",
    "eslint": "^9.36.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.22",
    "globals": "^16.4.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.14",
    "vite": "^7.1.7",
    "wait-on": "^7.0.1"
  },
  "build": {
    "appId": "com.sigma.os",
    "productName": "SIGMA_OS",
    "asar": true,
    "asarUnpack": [
      "backend/**",
      "intelligent_agents/**"
    ],
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "main.cjs",
      "logo.png",
      "package.json",
      "backend/**/*",
      "intelligent_agents/**/*"
    ],
    "extraResources": [
      {
        "from": "logo.png",
        "to": "logo.png"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "logo.png"
    },
    "nsis": {
      "shortcutName": "SIGMA_OS",
      "createDesktopShortcut": true
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "icon": "logo.png",
      "category": "Utility"
    }
  }
}
